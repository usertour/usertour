{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@/(.*)$": "<rootDir>/src/$1",
    "^ai$": "<rootDir>/test/mocks/ai-sdk.stub.ts",
    "^@ai-sdk/anthropic$": "<rootDir>/test/mocks/ai-sdk.stub.ts",
    "^@ai-sdk/openai-compatible$": "<rootDir>/test/mocks/ai-sdk.stub.ts"
  },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "<rootDir>/test/global-setup-e2e.ts",
  "setupFiles": ["<rootDir>/test/setup-e2e.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
