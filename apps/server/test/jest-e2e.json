{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "<rootDir>/test/global-setup-e2e.ts",
  "setupFiles": ["<rootDir>/test/setup-e2e.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
