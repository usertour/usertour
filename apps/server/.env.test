# Environment for e2e tests (test/jest-e2e.json loads this via test/setup-e2e.ts).
# Points at the dedicated test database — never the dev database, since e2e
# specs seed and tear down real rows. Override by exporting DATABASE_URL before
# running if you need a different test database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/usertour_test?schema=public

# Neutralize OUTBOUND email in e2e while keeping the email features testable.
# The app otherwise boots with the dev `.env` SMTP creds, so specs like
# team.inviteTeamMember / auth.createMagicLink would send REAL emails on every
# run. The hard guarantee is the SMTP HOST: pointing it at a dead local port
# means any actual send (done async by a BullMQ worker) hits 127.0.0.1:2 →
# connection refused → nothing ever leaves the machine. EMAIL_AUTH_ENABLED stays
# true so the email-gated resolvers still run (their DB side effects are what the
# specs assert). setup-e2e loads these into process.env before the app boots, and
# they take precedence over `.env`.
EMAIL_AUTH_ENABLED=true
EMAIL_HOST=127.0.0.1
EMAIL_PORT=2
EMAIL_USER=disabled
EMAIL_PASS=disabled
EMAIL_SENDER=e2e-no-send@localhost
