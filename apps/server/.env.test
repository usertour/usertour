# Environment for e2e tests (test/jest-e2e.json loads this via test/setup-e2e.ts).
# Points at the dedicated test database — never the dev database, since e2e
# specs seed and tear down real rows. Override by exporting DATABASE_URL before
# running if you need a different test database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/usertour_test?schema=public
