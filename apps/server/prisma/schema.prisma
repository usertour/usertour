datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // PgBouncer connection
  directUrl = env("DATABASE_DIRECT_URL") // Direct PostgreSQL connection
}

generator client {
  provider = "prisma-client-js"

  // previewFeatures = []
}

generator dbml {
  provider = "prisma-dbml-generator"
}

model Account {
  /// Primary key
  id                String   @id @default(cuid())
  /// Create timestamp
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  /// Update timestamp
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)
  /// User
  user              User     @relation(fields: [userId], references: [id])
  /// User ID
  userId            String
  /// Account type
  type              String
  /// Provider  
  provider          String
  /// Provider account ID
  providerAccountId String
  /// Refresh token
  refreshToken      String?
  /// Access token
  accessToken       String?
  /// Token expiration timestamp
  expiresAt         Int?
  /// Scope
  scope             String?

  @@unique([provider, providerAccountId])
}

model User {
  id                     String                  @id @default(cuid())
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @db.Timestamptz(6)
  email                  String?                 @unique
  emailVerified          DateTime?               @db.Timestamptz()
  password               String?
  avatarUrl              String?
  name                   String?
  /// Whether the user is a system admin (self-host only)
  isSystemAdmin          Boolean                 @default(false)
  /// Whether the user is disabled (cannot login)
  disabled               Boolean                 @default(false)
  /// Whether the user has completed TOTP two-factor setup
  twoFactorEnabled       Boolean                 @default(false)
  /// AES-256-GCM encrypted TOTP secret. Never log or expose.
  twoFactorSecret        String?
  /// Timestamp when 2FA was last enabled
  twoFactorEnabledAt     DateTime?               @db.Timestamptz(6)
  projects               UserOnProject[]
  codes                  Code[]
  accounts               Account[]
  refreshTokens          RefreshToken[]
  invites                Invite[]
  twoFactorRecoveryCodes TwoFactorRecoveryCode[]
  apiTokens              ApiToken[]
}

/// One-time backup codes for 2FA account recovery. Stored as bcrypt hash.
model TwoFactorRecoveryCode {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  hashedCode String
  usedAt     DateTime? @db.Timestamptz(6)

  @@index([userId])
}

/// Instance-level settings for self-hosted mode
model InstanceSetting {
  /// Primary key
  id                                      String   @id @default(cuid())
  /// Singleton key to ensure exactly one instance setting record exists
  key                                     String   @unique @default("instance")
  /// Stable instance identifier
  instanceId                              String   @unique @default(cuid())
  /// Instance display name
  name                                    String?
  /// Instance system admin contact email
  contactEmail                            String?
  /// Whether public user registration is allowed
  allowUserRegistration                   Boolean  @default(true)
  /// Whether all users must enable 2FA. Only meaningful in self-hosted mode.
  require2FA                              Boolean  @default(false)
  /// Whether self-host projects can manage project-level subscriptions
  allowProjectLevelSubscriptionManagement Boolean?
  /// Instance-level license JWT token
  license                                 String?
  /// Create timestamp
  createdAt                               DateTime @default(now()) @db.Timestamptz(6)
  /// Update timestamp
  updatedAt                               DateTime @updatedAt @db.Timestamptz(6)
}

model Register {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  code      String   @default(cuid())
  email     String
  processed Boolean  @default(false)
}

model Invite {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  code      String    @unique @default(cuid())
  /// Environment ids the invited member may act on once they join (copied to
  /// UserOnProject on accept). null = all environments.
  allowedEnvironmentIds Json? @db.JsonB
  expired   Boolean   @default(false)
  canceled  Boolean   @default(false)
  deleted   Boolean   @default(false)
  email     String
  name      String
  role      Role
  /// When the invite link stops being accepted. Nullable so the column can
  /// roll out without a backfill; rows written by the application always set
  /// it (typically createdAt + 14 days). getValidInviteByCode treats a null
  /// value as "no recorded TTL" — legacy invites stay accepting until an
  /// admin cancels them, but every new invite is bounded.
  expiresAt DateTime? @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  project   Project   @relation(fields: [projectId], references: [id])
  projectId String
}

model Code {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  /// When this code stops being valid. Set at creation (typically createdAt + 1h).
  /// Codes are single-use (deleted on consumption); this protects against forwarded
  /// or leaked reset links that haven't been used yet.
  /// Nullable so a rolling self-hosted upgrade can land the schema before the
  /// new app instances are live — old instances continue to INSERT without
  /// expiresAt, and the `expiresAt > now()` read filter naturally treats
  /// those rows as expired.
  expiresAt DateTime? @db.Timestamptz(6)
  ext       Json?     @db.JsonB
}

model Project {
  id                  String                       @id @default(cuid())
  createdAt           DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                     @updatedAt @db.Timestamptz(6)
  name                String
  logoUrl             String?
  /// Whether this project is assigned to use the instance license entitlement
  usesInstanceLicense Boolean                      @default(false)
  /// Stripe customer ID
  customerId          String?
  /// Stripe subscription ID
  subscriptionId      String?
  /// License
  license             String?
  users               UserOnProject[]
  apiTokens           ApiTokenOnProject[]
  environments        Environment[]
  themes              Theme[]
  attributes          Attribute[]
  events              Event[]
  localizations       Localization[]
  invites             Invite[]
  contents            Content[]
  segments            Segment[]
  ssoProviders        ProjectSSOIdentityProvider[]
  ssoSettings         ProjectSsoSettings?
}

/// Project-level SSO settings: enforcement (requireSso) and JIT provisioning
/// (defaultRole, allowedDomains). One row per project, lazily created on first
/// write; absent row means defaults (no enforcement, ADMIN, trust the IdP).
/// Provisioning lives here — not per-provider — because it is a project policy
/// that should not differ between a project's connections.
model ProjectSsoSettings {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
  project        Project  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId      String   @unique
  /// When true, members of this project must sign in through an SSO provider;
  /// password/social login is rejected for everyone except the project OWNER
  /// and system admins (break-glass so an IdP outage cannot lock the project).
  requireSso     Boolean  @default(false)
  /// When true, a brand-new email that authenticates through this project's SSO
  /// is auto-created and joined (with defaultRole, gated by allowedDomains).
  /// When false (default) SSO never grants new team access on its own — the
  /// person must already be a member or hold an invite. Existing members and
  /// invited users sign in regardless of this flag.
  autoProvision  Boolean  @default(false)
  /// Role assigned to auto-provisioned users (autoProvision only). Restricted to
  /// ADMIN or VIEWER at the API layer (OWNER/USER are rejected).
  defaultRole    Role     @default(ADMIN)
  /// Optional unverified email-domain allow-list for auto-provisioning. Empty =
  /// trust the IdP. Only consulted when autoProvision is on.
  allowedDomains String[] @default([])
}

/// Per-project SSO identity provider (OIDC in v1; SAML reserved). Configured
/// at runtime by a project owner; gated by the project's ssoOidc/ssoSaml plan
/// feature. One project can hold several named connections. Provisioning policy
/// (default role, allowed domains) lives on ProjectSsoSettings, not here.
model ProjectSSOIdentityProvider {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(6)
  project          Project         @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId        String
  /// OIDC | SAML — only OIDC is used in v1
  type             SsoProviderType @default(OIDC)
  /// Admin-named connection, e.g. "Okta", "Azure Entra ID"
  name             String
  /// active | inactive | error — live login still re-checks plan entitlement
  status           String          @default("active")
  // --- OIDC ---
  issuer           String
  clientId         String
  clientSecret     String
  /// Optional explicit endpoint overrides; when absent they are discovered
  /// from the issuer's /.well-known/openid-configuration.
  authorizationUrl String?
  tokenUrl         String?
  userInfoUrl      String?

  @@index([projectId])
}

enum SsoProviderType {
  OIDC
  SAML
}

model UserOnProject {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  role      Role
  actived   Boolean
  /// Environment ids this member may act on (the third permission dimension,
  /// mirrors ApiToken.allowedEnvironmentIds). null = all environments; ignored
  /// for OWNER. Personal API keys inherit this as a ceiling.
  allowedEnvironmentIds Json? @db.JsonB
  project   Project? @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId String?
  userId    String?

  @@unique([projectId, userId])
}

model Environment {
  id                    String                 @id @default(cuid())
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)
  name                  String?
  token                 String                 @default(cuid())
  deleted               Boolean                @default(false)
  /// Whether this is the primary environment for the project
  isPrimary             Boolean                @default(false)
  project               Project                @relation(fields: [projectId], references: [id])
  projectId             String
  contents              Content[]
  bizUsers              BizUser[]
  bizCompanies          BizCompany[]
  segments              Segment[]
  accessTokens          AccessToken[]
  contentOnEnvironments ContentOnEnvironment[]
  bizSessions           BizSession[]
  integrations          Integration[]
}

model AccessToken {
  id            String      @id @default(cuid())
  prefix        String      @default("ak_")
  accessToken   String      @unique @default(cuid())
  name          String
  environment   Environment @relation(fields: [environmentId], references: [id])
  environmentId String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  expiresAt     DateTime?   @db.Timestamptz(6)
  lastUsedAt    DateTime?   @db.Timestamptz(6)
  description   String?

  @@index([environmentId])
  @@index([accessToken])
}

/// User-owned API token for the public REST API (v2) and MCP/OAuth.
/// Authority at request time = ROLE_CAPABILITIES[owner's role on the project] ∩ scopes.
model ApiToken {
  id                    String              @id @default(cuid())
  createdAt             DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @db.Timestamptz(6)
  name                  String
  prefix                String              @default("utp_")
  /// SHA-256 hash of the token secret. Plaintext is returned once at creation and never stored.
  hashedSecret          String              @unique
  /// Trailing characters of the secret, for display only (e.g. "···a1b2").
  partialKey            String
  /// Capability[] (from @usertour/types) the token may exercise, intersected with the owner's role per request.
  scopes                Json                @db.JsonB
  /// Environment ids this token may ACT ON (read + write of env-scoped resources, and publish).
  /// null/absent = all environments in the token's project(s) — legacy/back-compat default.
  allowedEnvironmentIds Json?               @db.JsonB
  /// Set when issued via an OAuth grant; null for user-created personal tokens.
  clientId              String?
  /// The OAuthGrant that issued this access token; revoking the grant kills it.
  oauthGrantId          String?
  isActive              Boolean             @default(true)
  expiresAt             DateTime?           @db.Timestamptz(6)
  lastUsedAt            DateTime?           @db.Timestamptz(6)
  user                  User                @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId                String
  projects              ApiTokenOnProject[]

  @@index([userId])
  @@index([hashedSecret])
  @@index([clientId])
  @@index([oauthGrantId])
}

/// Join table scoping an ApiToken to one or more projects (mirrors UserOnProject).
model ApiTokenOnProject {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  apiToken   ApiToken? @relation(fields: [apiTokenId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  apiTokenId String?
  projectId  String?

  @@unique([apiTokenId, projectId])
}

/// An OAuth 2.1 client (Phase 3). Created via Dynamic Client Registration (RFC
/// 7591) or seeded; project-agnostic — the project is chosen by the user at
/// consent time. Public clients (MCP connectors) have no secret and use PKCE.
model OAuthClient {
  id                          String    @id @default(cuid()) // = client_id
  createdAt                   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @db.Timestamptz(6)
  clientType                  String // 'public' | 'confidential'
  /// bcrypt/SHA-256 hash of the client secret; null for public clients (PKCE).
  clientSecretHash            String?
  name                        String
  /// string[] of exact-match redirect URIs.
  redirectUris                Json      @db.JsonB
  /// string[] of granted grant types.
  grantTypes                  Json      @db.JsonB
  logoUri                     String?
  clientUri                   String?
  /// SHA-256 hash of the RFC 7592 registration access token (manage this client).
  registrationAccessTokenHash String?   @unique
  /// The user who registered it interactively; null for pure DCR.
  createdByUserId             String?
  lastUsedAt                  DateTime? @db.Timestamptz(6)

  @@index([createdByUserId])
}

/// A one-time OAuth authorization code (short TTL). Carries the consent decision
/// (chosen project + scopes) and the PKCE challenge until token exchange.
model OAuthAuthorizationCode {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  /// SHA-256 hash of the code; the plaintext is only in the redirect.
  hashedCode            String    @unique
  clientId              String
  userId                String
  projectId             String
  scopes                Json      @db.JsonB
  /// Environment ids the consent granted; carried to the grant/token. null = all (Phase 2).
  allowedEnvironmentIds Json?     @db.JsonB
  redirectUri           String
  codeChallenge         String?
  codeChallengeMethod   String? // 'S256'
  grantId               String
  resource              String?
  expiresAt             DateTime  @db.Timestamptz(6)
  consumedAt            DateTime? @db.Timestamptz(6)

  @@index([clientId])
}

/// A durable OAuth grant: the user's standing authorization of a client for a
/// project, and the current (rotating) refresh token. Revoking it cascade-kills
/// the access tokens (ApiToken rows) it issued, via ApiToken.oauthGrantId.
model OAuthGrant {
  id                    String    @id @default(cuid()) // = grantId
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)
  // Rolled up from the grant's short-lived access-token rows before the hourly
  // expiry cleanup deletes them — the durable "last used" for Connected Apps.
  lastUsedAt            DateTime? @db.Timestamptz(6)
  userId                String
  clientId              String
  projectId             String
  scopes                Json      @db.JsonB
  /// Environment ids this grant's issued tokens may act on; null = all (set at consent, Phase 2).
  allowedEnvironmentIds Json?     @db.JsonB
  /// SHA-256 hash of the current refresh token; rotated on each refresh.
  hashedRefreshToken    String?   @unique
  refreshExpiresAt      DateTime? @db.Timestamptz(6)
  revokedAt             DateTime? @db.Timestamptz(6)

  @@index([userId, clientId])
  @@index([clientId])
}

model Theme {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  name       String    @default("")
  isDefault  Boolean   @default(false)
  isSystem   Boolean   @default(false)
  deleted    Boolean   @default(false)
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  // settings  String
  settings   Json?     @db.JsonB
  /// Conditional variations
  variations Json?     @db.JsonB
  steps      Step[]
  versions   Version[]
}

model Content {
  id                    String                 @id @default(cuid())
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)
  publishedAt           DateTime?              @default(now()) @db.Timestamptz(6)
  name                  String?
  buildUrl              String?
  type                  String                 @default("flow")
  published             Boolean                @default(false)
  deleted               Boolean                @default(false)
  environment           Environment?           @relation(fields: [environmentId], references: [id])
  environmentId         String?
  project               Project?               @relation(fields: [projectId], references: [id])
  projectId             String?
  config                Json?                  @db.JsonB
  versions              Version[]              @relation("ContentVersions")
  editedVersion         Version?               @relation("EditedVersion", fields: [editedVersionId], references: [id])
  publishedVersion      Version?               @relation("publishedVersion", fields: [publishedVersionId], references: [id])
  /// @deprecated Legacy field from before `contentOnEnvironments` existed. The real
  /// per-environment published version lives in `contentOnEnvironments[env].publishedVersionId`.
  /// Resolve via `getPublishedVersionId` (serving) or `resolveContentVersionId` (analytics).
  /// Reading this field directly picks the wrong version in multi-environment setups.
  publishedVersionId    String?                @unique
  editedVersionId       String?                @unique
  bizSession            BizSession[]
  contentOnEnvironments ContentOnEnvironment[]
  publishRecords        ContentPublishRecord[]
}

model ContentOnEnvironment {
  id                 String      @id @default(cuid())
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @db.Timestamptz(6)
  environment        Environment @relation(fields: [environmentId], references: [id])
  environmentId      String
  content            Content     @relation(fields: [contentId], references: [id])
  contentId          String
  published          Boolean     @default(false)
  publishedAt        DateTime    @default(now()) @db.Timestamptz(6)
  publishedVersion   Version     @relation(fields: [publishedVersionId], references: [id])
  publishedVersionId String

  @@unique([environmentId, contentId])
}

/// One publish / unpublish event — the per-content "Publish history" product
/// surface (permanent, content-scoped, visible to anyone who can read the
/// content). Deliberately NOT derived from AuditLog: audit is owner-only,
/// plan-gated and read-time windowed; this is product data written in the same
/// transaction as the publish itself. Actor is either-or (web user OR the API
/// key/OAuth token that acted) — plain ids, no FKs, mirroring AuditLog: records
/// outlive users/tokens/environments; names resolve at read time.
model ContentPublishRecord {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId       String
  versionId       String
  /// Denormalized so "v3" still renders if the version row is later deleted.
  versionSequence Int
  environmentId   String
  /// publish | unpublish
  action          String
  actorUserId     String?
  actorTokenId    String?

  @@index([contentId, createdAt])
}

model Version {
  id                    String                  @id @default(cuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(6)
  publishedAt           DateTime?               @db.Timestamptz(6)
  scheduledAt           DateTime?               @db.Timestamptz(6)
  deleted               Boolean                 @default(false)
  sequence              Int                     @default(0)
  /// Who created this version row (web session user, or the API key's owner).
  /// Nullable: rows predating the column, and system-created seeds.
  createdByUserId       String?
  /// Who last wrote the version ROW (whole-version save / scalar fields). Step
  /// sub-row operations (sequence drag, location data) don't bump the row's
  /// updatedAt and intentionally don't restamp this either — the pair stays consistent.
  updatedByUserId       String?
  theme                 Theme?                  @relation(fields: [themeId], references: [id])
  themeId               String?
  content               Content                 @relation("ContentVersions", fields: [contentId], references: [id])
  contentId             String
  data                  Json?                   @db.JsonB
  config                Json?                   @db.JsonB
  steps                 Step[]
  editByContent         Content?                @relation("EditedVersion")
  publishByContent      Content?                @relation("publishedVersion")
  bizSession            BizSession[]
  versionOnLocalization VersionOnLocalization[]
  contentOnEnvironment  ContentOnEnvironment[]

  @@unique([contentId, sequence])
}

model Step {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  sequence   Int      @default(0)
  cvid       String   @default(cuid())
  name       String?
  type       String?
  target     Json?    @db.JsonB
  data       Json?    @db.JsonB
  trigger    Json?    @db.JsonB
  setting    Json?    @db.JsonB
  screenshot Json?    @db.JsonB
  theme      Theme?   @relation(fields: [themeId], references: [id])
  themeId    String?
  version    Version  @relation(fields: [versionId], references: [id])
  versionId  String

  @@unique([versionId, cvid])
  @@unique([versionId, sequence])
}

model Localization {
  id                    String                  @id @default(cuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(6)
  locale                String
  name                  String
  code                  String
  isDefault             Boolean                 @default(false)
  project               Project                 @relation(fields: [projectId], references: [id])
  projectId             String
  VersionOnLocalization VersionOnLocalization[]

  @@unique([projectId, code])
}

model VersionOnLocalization {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  version        Version      @relation(fields: [versionId], references: [id])
  versionId      String
  enabled        Boolean      @default(false)
  localization   Localization @relation(fields: [localizationId], references: [id])
  localizationId String
  localized      Json         @db.JsonB
  backup         Json         @db.JsonB

  @@unique([versionId, localizationId])
}

enum Role {
  ADMIN
  VIEWER
  USER
  OWNER
}

model Attribute {
  id               String             @id @default(cuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  bizType          Int                @default(1)
  project          Project            @relation(fields: [projectId], references: [id])
  projectId        String
  displayName      String             @default("")
  codeName         String             @default("")
  description      String             @default("")
  dataType         Int                @default(1)
  randomMax        Int                @default(1)
  source           String             @default("internal")
  predefined       Boolean            @default(false)
  deleted          Boolean            @default(false)
  attributeOnEvent AttributeOnEvent[]

  @@unique([projectId, bizType, codeName])
}

model BizUser {
  id                  String                @id @default(cuid())
  createdAt           DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @db.Timestamptz(6)
  environment         Environment           @relation(fields: [environmentId], references: [id])
  environmentId       String
  externalId          String                @default("")
  data                Json?                 @db.JsonB
  deleted             Boolean               @default(false)
  bizUsersOnCompany   BizUserOnCompany[]
  bizCompany          BizCompany?           @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId        String?
  bizUsersOnSegment   BizUserOnSegment[]
  bizEvent            BizEvent[]
  bizSession          BizSession[]
  bizAnnouncementSeen BizAnnouncementSeen[]

  @@unique([environmentId, externalId])
  @@index([externalId])
}

model BizUserOnCompany {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  bizCompany   BizCompany @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String
  bizUser      BizUser    @relation(fields: [bizUserId], references: [id])
  bizUserId    String
  data         Json       @db.JsonB

  @@unique([bizCompanyId, bizUserId])
  @@index([bizUserId])
}

model BizCompany {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)
  environment           Environment           @relation(fields: [environmentId], references: [id])
  environmentId         String
  externalId            String                @default("")
  data                  Json?                 @db.JsonB
  deleted               Boolean               @default(false)
  bizUsersOnCompany     BizUserOnCompany[]
  bizUsers              BizUser[]
  bizCompaniesOnSegment BizCompanyOnSegment[]
  BizSession            BizSession[]
  BizEvent              BizEvent[]

  @@unique([environmentId, externalId])
  @@index([externalId])
}

model Segment {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)
  name                  String                @default("")
  bizType               Int                   @default(1)
  dataType              Int                   @default(1)
  /// Source of the segment (e.g., "mixpanel", "heap", etc.)
  source                String?               @default("internal")
  /// Source ID of the segment (e.g., "mixpanel_cohort_id")
  sourceId              String?
  environment           Environment?          @relation(fields: [environmentId], references: [id])
  environmentId         String?
  project               Project?              @relation(fields: [projectId], references: [id])
  projectId             String?
  columns               Json?                 @db.JsonB
  data                  Json?                 @db.JsonB
  deleted               Boolean               @default(false)
  bizUsersOnSegment     BizUserOnSegment[]
  bizCompaniesOnSegment BizCompanyOnSegment[]
}

model BizUserOnSegment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  segment   Segment  @relation(fields: [segmentId], references: [id])
  segmentId String
  bizUser   BizUser  @relation(fields: [bizUserId], references: [id])
  bizUserId String
  data      Json?    @db.JsonB

  @@unique([segmentId, bizUserId])
  @@index([bizUserId])
}

model BizCompanyOnSegment {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  segment      Segment    @relation(fields: [segmentId], references: [id])
  segmentId    String
  bizCompany   BizCompany @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String
  data         Json?      @db.JsonB

  @@unique([segmentId, bizCompanyId])
  @@index([bizCompanyId])
}

model Event {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  displayName String   @default("")
  codeName    String   @default("")
  description String   @default("")
  deleted     Boolean  @default(false)
  predefined  Boolean  @default(false)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  attributeOnEvent AttributeOnEvent[]
  bizEvent         BizEvent[]

  @@unique([codeName, projectId])
}

model AttributeOnEvent {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       Event     @relation(fields: [eventId], references: [id])
  eventId     String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  attributeId String

  @@unique([eventId, attributeId])
}

model BizSession {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)
  deleted       Boolean      @default(false)
  state         Int          @default(0)
  data          Json?        @db.JsonB
  progress      Int          @default(0)
  projectId     String       @default("")
  environment   Environment? @relation(fields: [environmentId], references: [id])
  environmentId String?
  bizUser       BizUser      @relation(fields: [bizUserId], references: [id])
  bizUserId     String
  bizCompany    BizCompany?  @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId  String?
  content       Content      @relation(fields: [contentId], references: [id])
  contentId     String
  version       Version      @relation(fields: [versionId], references: [id])
  versionId     String
  bizEvent      BizEvent[]
  currentStepId String?      @default("")

  @@index([bizUserId])
  @@index([contentId])
}

model BizEvent {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  event        Event       @relation(fields: [eventId], references: [id])
  eventId      String
  data         Json?       @db.JsonB
  bizUser      BizUser     @relation(fields: [bizUserId], references: [id])
  bizUserId    String
  bizSession   BizSession? @relation(fields: [bizSessionId], references: [id])
  bizSessionId String?
  bizCompany   BizCompany? @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String?
  contentId    String?
  versionId    String?

  @@index([bizUserId])
  @@index([bizSessionId])
  @@index([bizCompanyId])
  @@index([contentId])
}

// Read-state for announcements: one row per (user, announcement), created the
// first time the user sees it in the feed. The unique key makes marking seen
// idempotent (INSERT .. ON CONFLICT DO NOTHING), so no locking is needed and
// the insert's RETURNING set is the "first seen" edge that drives the
// ANNOUNCEMENT_SEEN analytics event. Insert-only — rows are never updated.
model BizAnnouncementSeen {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  bizUser   BizUser  @relation(fields: [bizUserId], references: [id])
  bizUserId String
  contentId String

  @@unique([bizUserId, contentId])
  @@index([contentId])
}

model BizAnswer {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  bizEventId    String
  bizSessionId  String
  contentId     String
  versionId     String
  bizUserId     String
  cvid          String
  environmentId String?
  numberAnswer  Int?
  textAnswer    String?
  listAnswer    String[]

  @@unique([bizSessionId, cvid])
  @@index([contentId, cvid, bizUserId])
  @@index([versionId, cvid, bizUserId])
  @@index([environmentId, contentId, cvid, bizUserId])
}

model RefreshToken {
  /// Primary key
  id          String   @id @default(cuid())
  /// Token ID
  jti         String   @unique
  /// User
  user        User     @relation(fields: [userId], references: [id])
  /// User ID
  userId      String
  /// Hashed refresh token
  hashedToken String
  /// Whether the token has been revoked
  revoked     Boolean  @default(false)
  /// Expiration timestamp
  expiresAt   DateTime @db.Timestamptz()
  /// Create timestamp
  createdAt   DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@index([userId])
}

/// Subscription plan
model SubscriptionPlan {
  /// Primary key
  id                String   @id @default(cuid())
  /// Subscription plan type
  planType          String
  /// Billing interval (monthly, yearly, etc.)
  interval          String
  /// Lookup key
  lookupKey         String
  /// Monthly active user count quota
  mauQuota          Int      @default(3000)
  /// Session count quota
  sessionCountQuota Int      @default(5000)
  /// Create timestamp
  createdAt         DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@unique([planType, interval])
}

/// Subscription
model Subscription {
  /// Primary key
  id             String    @id @default(cuid())
  /// Stripe subscription ID
  subscriptionId String    @unique
  /// Stripe price lookup key
  lookupKey      String
  /// Plan type (hobby, starter, growth, business)
  planType       String
  /// Billing interval (monthly, yearly, etc.)
  interval       String
  /// Project ID
  projectId      String
  /// Stripe subscription status
  status         String
  /// Whether this is a trial subscription
  isTrial        Boolean   @default(false)
  /// Override plan quota (JSON string)
  overridePlan   Json?     @db.JsonB
  /// Cancel timestamp
  cancelAt       DateTime? @db.Timestamptz()
  /// Create timestamp
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@index([projectId])
  @@index([status, cancelAt])
}

model CheckoutSession {
  /// Primary key
  id             String   @id @default(cuid())
  /// Stripe checkout session ID
  sessionId      String
  /// Project ID
  projectId      String
  /// Price lookup key
  lookupKey      String
  /// Payment status
  paymentStatus  String?
  /// Stripe subscription ID
  subscriptionId String?
  /// Stripe invoice ID
  invoiceId      String?
  /// Stripe customer ID
  customerId     String?
  /// Create timestamp
  createdAt      DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@index([sessionId])
}

model Integration {
  id                        String                     @id @default(cuid())
  /// code of rntegration (e.g., "ga", "mixpanel", "posthog")
  provider                  String
  /// api key or  of integration 
  key                       String                     @default("")
  /// access token of integration
  accessToken               String                     @unique @default(cuid())
  /// JSON schema for configuration (optional)
  config                    Json?                      @db.JsonB
  /// Whether the integration is enabled
  enabled                   Boolean                    @default(false)
  /// environment of integration
  environment               Environment                @relation(fields: [environmentId], references: [id])
  /// environment id
  environmentId             String
  /// Create timestamp
  createdAt                 DateTime                   @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt                 DateTime                   @default(now()) @updatedAt @db.Timestamptz()
  /// integration logs
  integrationLogs           IntegrationLog[]
  integrationOAuth          IntegrationOAuth?
  integrationObjectMappings IntegrationObjectMapping[]

  @@unique([environmentId, provider])
}

model IntegrationOAuth {
  /// primary key
  id                String      @id @default(cuid())
  /// create timestamp
  createdAt         DateTime    @default(now()) @db.Timestamptz(6)
  /// update timestamp
  updatedAt         DateTime    @updatedAt @db.Timestamptz(6)
  /// access token
  accessToken       String
  /// refresh token
  refreshToken      String
  /// expires at
  expiresAt         DateTime    @db.Timestamptz(6)
  /// data
  data              Json?       @db.JsonB
  /// scope
  scope             String // Space-separated OAuth scopes (e.g., "api refresh_token web")
  /// provider (e.g., "salesforce", "hubspot")
  provider          String
  /// provider account id
  providerAccountId String
  /// integration
  integration       Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId     String      @unique // One integration can only have one OAuth configuration

  @@index([integrationId])
}

model IntegrationObjectMapping {
  id                    String      @id @default(cuid())
  /// Create timestamp
  createdAt             DateTime    @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt             DateTime    @default(now()) @updatedAt @db.Timestamptz()
  /// source object type (e.g., "account", "contact", "lead")
  sourceObjectType      String
  /// destination object type (e.g., "user", "company")
  destinationObjectType String
  /// settings
  settings              Json?       @db.JsonB
  /// enabled
  enabled               Boolean     @default(false)
  /// is syncing
  isSyncing             Boolean     @default(false)
  /// last synced at
  lastSyncedAt          DateTime?   @db.Timestamptz()
  /// integration
  integration           Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId         String

  @@unique([integrationId, sourceObjectType, destinationObjectType])
}

model IntegrationLog {
  /// Primary key
  id            String      @id @default(cuid())
  /// Create timestamp
  createdAt     DateTime    @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt     DateTime    @updatedAt @db.Timestamptz()
  /// integration
  integration   Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId String
  /// status of integration log
  status        String
  /// data of integration log
  data          Json?       @db.JsonB

  @@index([integrationId, status])
}

/// Append-only audit trail for the open write surface (v2 API + MCP).
/// Typed columns are the query / filter / forensic axes; JSONB holds variable,
/// redacted detail (snapshots, request metadata) that is never used as a filter
/// predicate. No foreign keys on purpose: an audit row must outlive the entities
/// it references (resources may be hard-deleted, tokens rotated, users removed),
/// and `resourceId` is polymorphic across many tables. Rows are append-only.
model AuditLog {
  /// Primary key
  id        String   @id @default(cuid())
  /// Create timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Where (filter axes)
  projectId     String
  environmentId String?

  // Who / how (filter + forensic axes)
  source       String // 'api' | 'mcp' | 'web' | 'system'
  actorUserId  String?
  actorTokenId String?

  // What (filter axes)
  action       String // 'create' | 'update' | 'delete'
  operation    String // exact tool / route, e.g. 'delete_segment'
  resourceType String
  resourceId   String

  // Variable detail (never filtered on; redacted per resourceType policy)
  before   Json? @db.JsonB
  after    Json? @db.JsonB
  metadata Json? @db.JsonB

  @@index([projectId, resourceType, resourceId, createdAt])
  @@index([projectId, createdAt])
  @@index([projectId, source, createdAt])
  @@index([actorTokenId, createdAt])
  @@index([actorUserId, createdAt])
}
