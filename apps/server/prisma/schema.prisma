datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // PgBouncer connection
  directUrl = env("DATABASE_DIRECT_URL") // Direct PostgreSQL connection
}

generator client {
  provider = "prisma-client-js"

  // previewFeatures = []
}

generator dbml {
  provider = "prisma-dbml-generator"
}

model Account {
  /// Primary key
  id                String   @id @default(cuid())
  /// Create timestamp
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  /// Update timestamp
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)
  /// User
  user              User     @relation(fields: [userId], references: [id])
  /// User ID
  userId            String
  /// Account type
  type              String
  /// Provider  
  provider          String
  /// Provider account ID
  providerAccountId String
  /// Refresh token
  refreshToken      String?
  /// Access token
  accessToken       String?
  /// Token expiration timestamp
  expiresAt         Int?
  /// Scope
  scope             String?

  @@unique([provider, providerAccountId])
}

model User {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @db.Timestamptz(6)
  email           String?         @unique
  emailVerified   DateTime?       @db.Timestamptz()
  password        String?
  avatarUrl       String?
  name            String?
  /// Whether the user is a system admin (self-host only)
  isSystemAdmin   Boolean         @default(false)
  /// Whether the user is disabled (cannot login)
  disabled        Boolean         @default(false)
  /// Whether the user has completed TOTP two-factor setup
  twoFactorEnabled Boolean        @default(false)
  /// AES-256-GCM encrypted TOTP secret. Never log or expose.
  twoFactorSecret  String?
  /// Timestamp when 2FA was last enabled
  twoFactorEnabledAt DateTime?    @db.Timestamptz(6)
  projects        UserOnProject[]
  codes           Code[]
  accounts        Account[]
  refreshTokens   RefreshToken[]
  invites         Invite[]
  twoFactorRecoveryCodes TwoFactorRecoveryCode[]
}

/// One-time backup codes for 2FA account recovery. Stored as bcrypt hash.
model TwoFactorRecoveryCode {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  hashedCode String
  usedAt     DateTime? @db.Timestamptz(6)

  @@index([userId])
}

/// Instance-level settings for self-hosted mode
model InstanceSetting {
  /// Primary key
  id          String   @id @default(cuid())
  /// Singleton key to ensure exactly one instance setting record exists
  key         String   @unique @default("instance")
  /// Stable instance identifier
  instanceId  String   @unique @default(cuid())
  /// Instance display name
  name        String?
  /// Instance system admin contact email
  contactEmail String?
  /// Whether public user registration is allowed
  allowUserRegistration Boolean @default(true)
  /// Whether all users must enable 2FA. Only meaningful in self-hosted mode.
  require2FA  Boolean @default(false)
  /// Whether self-host projects can manage project-level subscriptions
  allowProjectLevelSubscriptionManagement Boolean?
  /// Instance-level license JWT token
  license     String?
  /// Create timestamp
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  /// Update timestamp
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
}

model Register {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  code      String   @default(cuid())
  email     String
  processed Boolean  @default(false)
}

model Invite {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  code      String    @unique @default(cuid())
  expired   Boolean   @default(false)
  canceled  Boolean   @default(false)
  deleted   Boolean   @default(false)
  email     String
  name      String
  role      Role
  /// When the invite link stops being accepted. Nullable so the column can
  /// roll out without a backfill; rows written by the application always set
  /// it (typically createdAt + 14 days). getValidInviteByCode treats a null
  /// value as "no recorded TTL" — legacy invites stay accepting until an
  /// admin cancels them, but every new invite is bounded.
  expiresAt DateTime? @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  project   Project   @relation(fields: [projectId], references: [id])
  projectId String
}

model Code {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  /// When this code stops being valid. Set at creation (typically createdAt + 1h).
  /// Codes are single-use (deleted on consumption); this protects against forwarded
  /// or leaked reset links that haven't been used yet.
  /// Nullable so a rolling self-hosted upgrade can land the schema before the
  /// new app instances are live — old instances continue to INSERT without
  /// expiresAt, and the `expiresAt > now()` read filter naturally treats
  /// those rows as expired.
  expiresAt DateTime? @db.Timestamptz(6)
  ext       Json?    @db.JsonB
}

model Project {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  name           String
  logoUrl        String?
  /// Whether this project is assigned to use the instance license entitlement
  usesInstanceLicense Boolean    @default(false)
  /// Stripe customer ID
  customerId     String?
  /// Stripe subscription ID
  subscriptionId String?
  /// License
  license        String?
  users          UserOnProject[]
  environments   Environment[]
  themes         Theme[]
  attributes     Attribute[]
  events         Event[]
  localizations  Localization[]
  invites        Invite[]
  contents       Content[]
  segments       Segment[]
  ssoProviders   ProjectSSOIdentityProvider[]
  ssoSettings    ProjectSsoSettings?
}

/// Project-level SSO settings: enforcement (requireSso) and JIT provisioning
/// (defaultRole, allowedDomains). One row per project, lazily created on first
/// write; absent row means defaults (no enforcement, ADMIN, trust the IdP).
/// Provisioning lives here — not per-provider — because it is a project policy
/// that should not differ between a project's connections.
model ProjectSsoSettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  project   Project  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId String   @unique
  /// When true, members of this project must sign in through an SSO provider;
  /// password/social login is rejected for everyone except the project OWNER
  /// and system admins (break-glass so an IdP outage cannot lock the project).
  requireSso     Boolean  @default(false)
  /// When true, a brand-new email that authenticates through this project's SSO
  /// is auto-created and joined (with defaultRole, gated by allowedDomains).
  /// When false (default) SSO never grants new team access on its own — the
  /// person must already be a member or hold an invite. Existing members and
  /// invited users sign in regardless of this flag.
  autoProvision  Boolean  @default(false)
  /// Role assigned to auto-provisioned users (autoProvision only). Restricted to
  /// ADMIN or VIEWER at the API layer (OWNER/USER are rejected).
  defaultRole    Role     @default(ADMIN)
  /// Optional unverified email-domain allow-list for auto-provisioning. Empty =
  /// trust the IdP. Only consulted when autoProvision is on.
  allowedDomains String[] @default([])
}

/// Per-project SSO identity provider (OIDC in v1; SAML reserved). Configured
/// at runtime by a project owner; gated by the project's ssoOidc/ssoSaml plan
/// feature. One project can hold several named connections. Provisioning policy
/// (default role, allowed domains) lives on ProjectSsoSettings, not here.
model ProjectSSOIdentityProvider {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  project   Project  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId String
  /// OIDC | SAML — only OIDC is used in v1
  type      SsoProviderType @default(OIDC)
  /// Admin-named connection, e.g. "Okta", "Azure Entra ID"
  name      String
  /// active | inactive | error — live login still re-checks plan entitlement
  status    String   @default("active")
  // --- OIDC ---
  issuer           String
  clientId         String
  clientSecret     String
  /// Optional explicit endpoint overrides; when absent they are discovered
  /// from the issuer's /.well-known/openid-configuration.
  authorizationUrl String?
  tokenUrl         String?
  userInfoUrl      String?

  @@index([projectId])
}

enum SsoProviderType {
  OIDC
  SAML
}

model UserOnProject {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  role      Role
  actived   Boolean
  project   Project? @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  projectId String?
  userId    String?

  @@unique([projectId, userId])
}

model Environment {
  id                    String                 @id @default(cuid())
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)
  name                  String?
  token                 String                 @default(cuid())
  deleted               Boolean                @default(false)
  /// Whether this is the primary environment for the project
  isPrimary             Boolean                @default(false)
  /// When true, SDK identity claims must carry a valid HMAC signature (ADR 0008)
  requireIdentityVerification Boolean          @default(false)
  project               Project                @relation(fields: [projectId], references: [id])
  projectId             String
  contents              Content[]
  bizUsers              BizUser[]
  bizCompanies          BizCompany[]
  segments              Segment[]
  accessTokens          AccessToken[]
  contentOnEnvironments ContentOnEnvironment[]
  bizSessions           BizSession[]
  integrations          Integration[]
  signingSecrets        EnvironmentSigningSecret[]
}

/// Per-environment HMAC signing secrets for SDK identity verification (ADR 0008).
/// At most 2 active (revokedAt = null) rows per environment — the steady-state
/// secret plus one rotation slot — enforced at the application layer.
model EnvironmentSigningSecret {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  environment   Environment @relation(fields: [environmentId], references: [id])
  environmentId String
  secret        String      @unique
  lastUsedAt    DateTime?   @db.Timestamptz(6)
  revokedAt     DateTime?   @db.Timestamptz(6)

  @@index([environmentId])
}

model AccessToken {
  id            String      @id @default(cuid())
  prefix        String      @default("ak_")
  accessToken   String      @unique @default(cuid())
  name          String
  environment   Environment @relation(fields: [environmentId], references: [id])
  environmentId String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  expiresAt     DateTime?   @db.Timestamptz(6)
  lastUsedAt    DateTime?   @db.Timestamptz(6)
  description   String?

  @@index([environmentId])
  @@index([accessToken])
}

model Theme {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  name       String    @default("")
  isDefault  Boolean   @default(false)
  isSystem   Boolean   @default(false)
  deleted    Boolean   @default(false)
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  // settings  String
  settings   Json?     @db.JsonB
  /// Conditional variations
  variations Json?     @db.JsonB
  steps      Step[]
  versions   Version[]
}

model Content {
  id                    String                 @id @default(cuid())
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)
  publishedAt           DateTime?              @default(now()) @db.Timestamptz(6)
  name                  String?
  buildUrl              String?
  type                  String                 @default("flow")
  published             Boolean                @default(false)
  deleted               Boolean                @default(false)
  environment           Environment?           @relation(fields: [environmentId], references: [id])
  environmentId         String?
  project               Project?               @relation(fields: [projectId], references: [id])
  projectId             String?
  config                Json?                  @db.JsonB
  versions              Version[]              @relation("ContentVersions")
  editedVersion         Version?               @relation("EditedVersion", fields: [editedVersionId], references: [id])
  publishedVersion      Version?               @relation("publishedVersion", fields: [publishedVersionId], references: [id])
  /// @deprecated Legacy field from before `contentOnEnvironments` existed. The real
  /// per-environment published version lives in `contentOnEnvironments[env].publishedVersionId`.
  /// Resolve via `getPublishedVersionId` (serving) or `resolveContentVersionId` (analytics).
  /// Reading this field directly picks the wrong version in multi-environment setups.
  publishedVersionId    String?                @unique
  editedVersionId       String?                @unique
  bizSession            BizSession[]
  contentOnEnvironments ContentOnEnvironment[]
}

model ContentOnEnvironment {
  id                 String      @id @default(cuid())
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @db.Timestamptz(6)
  environment        Environment @relation(fields: [environmentId], references: [id])
  environmentId      String
  content            Content     @relation(fields: [contentId], references: [id])
  contentId          String
  published          Boolean     @default(false)
  publishedAt        DateTime    @default(now()) @db.Timestamptz(6)
  publishedVersion   Version     @relation(fields: [publishedVersionId], references: [id])
  publishedVersionId String

  @@unique([environmentId, contentId])
}

model Version {
  id                    String                  @id @default(cuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(6)
  publishedAt           DateTime?               @db.Timestamptz(6)
  scheduledAt           DateTime?               @db.Timestamptz(6)
  deleted               Boolean                 @default(false)
  sequence              Int                     @default(0)
  theme                 Theme?                  @relation(fields: [themeId], references: [id])
  themeId               String?
  content               Content                 @relation("ContentVersions", fields: [contentId], references: [id])
  contentId             String
  data                  Json?                   @db.JsonB
  config                Json?                   @db.JsonB
  steps                 Step[]
  editByContent         Content?                @relation("EditedVersion")
  publishByContent      Content?                @relation("publishedVersion")
  bizSession            BizSession[]
  versionOnLocalization VersionOnLocalization[]
  contentOnEnvironment  ContentOnEnvironment[]

  @@unique([contentId, sequence])
}

model Step {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  sequence   Int      @default(0)
  cvid       String   @default(cuid())
  name       String?
  type       String?
  target     Json?    @db.JsonB
  data       Json?    @db.JsonB
  trigger    Json?    @db.JsonB
  setting    Json?    @db.JsonB
  screenshot Json?    @db.JsonB
  theme      Theme?   @relation(fields: [themeId], references: [id])
  themeId    String?
  version    Version  @relation(fields: [versionId], references: [id])
  versionId  String

  @@unique([versionId, cvid])
  @@unique([versionId, sequence])
}

model Localization {
  id                    String                  @id @default(cuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(6)
  locale                String
  name                  String
  code                  String
  isDefault             Boolean                 @default(false)
  project               Project                 @relation(fields: [projectId], references: [id])
  projectId             String
  VersionOnLocalization VersionOnLocalization[]

  @@unique([projectId, code])
}

model VersionOnLocalization {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  version        Version      @relation(fields: [versionId], references: [id])
  versionId      String
  enabled        Boolean      @default(false)
  localization   Localization @relation(fields: [localizationId], references: [id])
  localizationId String
  localized      Json         @db.JsonB
  backup         Json         @db.JsonB

  @@unique([versionId, localizationId])
}

enum Role {
  ADMIN
  VIEWER
  USER
  OWNER
}

model Attribute {
  id               String             @id @default(cuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  bizType          Int                @default(1)
  project          Project            @relation(fields: [projectId], references: [id])
  projectId        String
  displayName      String             @default("")
  codeName         String             @default("")
  description      String             @default("")
  dataType         Int                @default(1)
  randomMax        Int                @default(1)
  source           String             @default("internal")
  predefined       Boolean            @default(false)
  deleted          Boolean            @default(false)
  attributeOnEvent AttributeOnEvent[]

  @@unique([projectId, bizType, codeName])
}

model BizUser {
  id                  String                @id @default(cuid())
  createdAt           DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @db.Timestamptz(6)
  environment         Environment           @relation(fields: [environmentId], references: [id])
  environmentId       String
  externalId          String                @default("")
  data                Json?                 @db.JsonB
  deleted             Boolean               @default(false)
  bizUsersOnCompany   BizUserOnCompany[]
  bizCompany          BizCompany?           @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId        String?
  bizUsersOnSegment   BizUserOnSegment[]
  bizEvent            BizEvent[]
  bizSession          BizSession[]
  bizAnnouncementSeen BizAnnouncementSeen[]

  @@unique([environmentId, externalId])
  @@index([externalId])
}

model BizUserOnCompany {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  bizCompany   BizCompany @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String
  bizUser      BizUser    @relation(fields: [bizUserId], references: [id])
  bizUserId    String
  data         Json       @db.JsonB

  @@unique([bizCompanyId, bizUserId])
  @@index([bizUserId])
}

model BizCompany {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)
  environment           Environment           @relation(fields: [environmentId], references: [id])
  environmentId         String
  externalId            String                @default("")
  data                  Json?                 @db.JsonB
  deleted               Boolean               @default(false)
  bizUsersOnCompany     BizUserOnCompany[]
  bizUsers              BizUser[]
  bizCompaniesOnSegment BizCompanyOnSegment[]
  BizSession            BizSession[]
  BizEvent              BizEvent[]

  @@unique([environmentId, externalId])
  @@index([externalId])
}

model Segment {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)
  name                  String                @default("")
  bizType               Int                   @default(1)
  dataType              Int                   @default(1)
  /// Source of the segment (e.g., "mixpanel", "heap", etc.)
  source                String?               @default("internal")
  /// Source ID of the segment (e.g., "mixpanel_cohort_id")
  sourceId              String?
  environment           Environment?          @relation(fields: [environmentId], references: [id])
  environmentId         String?
  project               Project?              @relation(fields: [projectId], references: [id])
  projectId             String?
  columns               Json?                 @db.JsonB
  data                  Json?                 @db.JsonB
  deleted               Boolean               @default(false)
  bizUsersOnSegment     BizUserOnSegment[]
  bizCompaniesOnSegment BizCompanyOnSegment[]
}

model BizUserOnSegment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  segment   Segment  @relation(fields: [segmentId], references: [id])
  segmentId String
  bizUser   BizUser  @relation(fields: [bizUserId], references: [id])
  bizUserId String
  data      Json?    @db.JsonB

  @@unique([segmentId, bizUserId])
  @@index([bizUserId])
}

model BizCompanyOnSegment {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  segment      Segment    @relation(fields: [segmentId], references: [id])
  segmentId    String
  bizCompany   BizCompany @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String
  data         Json?      @db.JsonB

  @@unique([segmentId, bizCompanyId])
  @@index([bizCompanyId])
}

model Event {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  displayName String   @default("")
  codeName    String   @default("")
  description String   @default("")
  deleted     Boolean  @default(false)
  predefined  Boolean  @default(false)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  attributeOnEvent AttributeOnEvent[]
  bizEvent         BizEvent[]

  @@unique([codeName, projectId])
}

model AttributeOnEvent {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       Event     @relation(fields: [eventId], references: [id])
  eventId     String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  attributeId String

  @@unique([eventId, attributeId])
}

model BizSession {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)
  deleted       Boolean      @default(false)
  state         Int          @default(0)
  data          Json?        @db.JsonB
  progress      Int          @default(0)
  projectId     String       @default("")
  environment   Environment? @relation(fields: [environmentId], references: [id])
  environmentId String?
  bizUser       BizUser      @relation(fields: [bizUserId], references: [id])
  bizUserId     String
  bizCompany    BizCompany?  @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId  String?
  content       Content      @relation(fields: [contentId], references: [id])
  contentId     String
  version       Version      @relation(fields: [versionId], references: [id])
  versionId     String
  bizEvent      BizEvent[]
  currentStepId String?      @default("")

  @@index([bizUserId])
  @@index([contentId])
}

model BizEvent {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  event        Event       @relation(fields: [eventId], references: [id])
  eventId      String
  data         Json?       @db.JsonB
  bizUser      BizUser     @relation(fields: [bizUserId], references: [id])
  bizUserId    String
  bizSession   BizSession? @relation(fields: [bizSessionId], references: [id])
  bizSessionId String?
  bizCompany   BizCompany? @relation(fields: [bizCompanyId], references: [id])
  bizCompanyId String?
  contentId    String?
  versionId    String?

  @@index([bizUserId])
  @@index([bizSessionId])
  @@index([bizCompanyId])
  @@index([contentId])
}

// Read-state for announcements: one row per (user, announcement), created the
// first time the user sees it in the feed. The unique key makes marking seen
// idempotent (INSERT .. ON CONFLICT DO NOTHING), so no locking is needed and
// the insert's RETURNING set is the "first seen" edge that drives the
// ANNOUNCEMENT_SEEN analytics event. Insert-only — rows are never updated.
model BizAnnouncementSeen {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  bizUser   BizUser  @relation(fields: [bizUserId], references: [id])
  bizUserId String
  contentId String

  @@unique([bizUserId, contentId])
  @@index([contentId])
}

model BizAnswer {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  bizEventId    String
  bizSessionId  String
  contentId     String
  versionId     String
  bizUserId     String
  cvid          String
  environmentId String?
  numberAnswer  Int?
  textAnswer    String?
  listAnswer    String[]

  @@unique([bizSessionId, cvid])
  @@index([contentId, cvid, bizUserId])
  @@index([versionId, cvid, bizUserId])
  @@index([environmentId, contentId, cvid, bizUserId])
}

model RefreshToken {
  /// Primary key
  id          String   @id @default(cuid())
  /// Token ID
  jti         String   @unique
  /// User
  user        User     @relation(fields: [userId], references: [id])
  /// User ID
  userId      String
  /// Hashed refresh token
  hashedToken String
  /// Whether the token has been revoked
  revoked     Boolean  @default(false)
  /// Expiration timestamp
  expiresAt   DateTime @db.Timestamptz()
  /// Create timestamp
  createdAt   DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@index([userId])
}

/// Subscription plan
model SubscriptionPlan {
  /// Primary key
  id                String   @id @default(cuid())
  /// Subscription plan type
  planType          String
  /// Billing interval (monthly, yearly, etc.)
  interval          String
  /// Lookup key
  lookupKey         String
  /// Monthly active user count quota
  mauQuota          Int      @default(3000)
  /// Session count quota
  sessionCountQuota Int      @default(5000)
  /// Create timestamp
  createdAt         DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@unique([planType, interval])
}

/// Subscription
model Subscription {
  /// Primary key
  id             String    @id @default(cuid())
  /// Stripe subscription ID
  subscriptionId String    @unique
  /// Stripe price lookup key
  lookupKey      String
  /// Plan type (hobby, starter, growth, business)
  planType       String
  /// Billing interval (monthly, yearly, etc.)
  interval       String
  /// Project ID
  projectId      String
  /// Stripe subscription status
  status         String
  /// Whether this is a trial subscription
  isTrial        Boolean   @default(false)
  /// Override plan quota (JSON string)
  overridePlan   Json?     @db.JsonB
  /// Cancel timestamp
  cancelAt       DateTime? @db.Timestamptz()
  /// Create timestamp
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@index([projectId])
  @@index([status, cancelAt])
}

model CheckoutSession {
  /// Primary key
  id             String   @id @default(cuid())
  /// Stripe checkout session ID
  sessionId      String
  /// Project ID
  projectId      String
  /// Price lookup key
  lookupKey      String
  /// Payment status
  paymentStatus  String?
  /// Stripe subscription ID
  subscriptionId String?
  /// Stripe invoice ID
  invoiceId      String?
  /// Stripe customer ID
  customerId     String?
  /// Create timestamp
  createdAt      DateTime @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@index([sessionId])
}

model Integration {
  id                        String                     @id @default(cuid())
  /// code of rntegration (e.g., "ga", "mixpanel", "posthog")
  provider                  String
  /// api key or  of integration 
  key                       String                     @default("")
  /// access token of integration
  accessToken               String                     @unique @default(cuid())
  /// JSON schema for configuration (optional)
  config                    Json?                      @db.JsonB
  /// Whether the integration is enabled
  enabled                   Boolean                    @default(false)
  /// environment of integration
  environment               Environment                @relation(fields: [environmentId], references: [id])
  /// environment id
  environmentId             String
  /// Create timestamp
  createdAt                 DateTime                   @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt                 DateTime                   @default(now()) @updatedAt @db.Timestamptz()
  /// integration logs
  integrationLogs           IntegrationLog[]
  integrationOAuth          IntegrationOAuth?
  integrationObjectMappings IntegrationObjectMapping[]

  @@unique([environmentId, provider])
}

model IntegrationOAuth {
  /// primary key
  id                String      @id @default(cuid())
  /// create timestamp
  createdAt         DateTime    @default(now()) @db.Timestamptz(6)
  /// update timestamp
  updatedAt         DateTime    @updatedAt @db.Timestamptz(6)
  /// access token
  accessToken       String
  /// refresh token
  refreshToken      String
  /// expires at
  expiresAt         DateTime    @db.Timestamptz(6)
  /// data
  data              Json?       @db.JsonB
  /// scope
  scope             String // Space-separated OAuth scopes (e.g., "api refresh_token web")
  /// provider (e.g., "salesforce", "hubspot")
  provider          String
  /// provider account id
  providerAccountId String
  /// integration
  integration       Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId     String      @unique // One integration can only have one OAuth configuration

  @@index([integrationId])
}

model IntegrationObjectMapping {
  id                    String      @id @default(cuid())
  /// Create timestamp
  createdAt             DateTime    @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt             DateTime    @default(now()) @updatedAt @db.Timestamptz()
  /// source object type (e.g., "account", "contact", "lead")
  sourceObjectType      String
  /// destination object type (e.g., "user", "company")
  destinationObjectType String
  /// settings
  settings              Json?       @db.JsonB
  /// enabled
  enabled               Boolean     @default(false)
  /// is syncing
  isSyncing             Boolean     @default(false)
  /// last synced at
  lastSyncedAt          DateTime?   @db.Timestamptz()
  /// integration
  integration           Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId         String

  @@unique([integrationId, sourceObjectType, destinationObjectType])
}

model IntegrationLog {
  /// Primary key
  id            String      @id @default(cuid())
  /// Create timestamp
  createdAt     DateTime    @default(now()) @db.Timestamptz()
  /// Update timestamp
  updatedAt     DateTime    @updatedAt @db.Timestamptz()
  /// integration
  integration   Integration @relation(fields: [integrationId], references: [id])
  /// integration id
  integrationId String
  /// status of integration log
  status        String
  /// data of integration log
  data          Json?       @db.JsonB

  @@index([integrationId, status])
}
