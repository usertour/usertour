{
  "name": "@usertour-packages/constants",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "build:fast": "tsup --no-dts"
  },
  "dependencies": {
    "@usertour/types": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.0.2"
  },
  "tsup": {
    "clean": true,
    "target": "es2019",
    "format": ["cjs", "esm"],
    "entry": ["src/index.ts"],
    "outDir": "dist",
    "dts": true
  }
}
