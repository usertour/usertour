    "build:fast": "tsup src"
  },
  "dependencies": {
    "@base-ui/react": "1.0.0-rc.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@tabler/icons-react": "^3.31.0",
    "@usertour/alert": "workspace:*",
    "@usertour/button": "workspace:*",
    "@usertour/calendar": "workspace:*",
    "@usertour/command": "workspace:*",
    "@usertour/constants": "workspace:*",
    "@usertour/dropdown-menu": "workspace:*",
    "@usertour/icons": "workspace:*",
    "@usertour/input": "workspace:*",
    "@usertour/popover": "workspace:*",
    "@usertour/scroll-area": "workspace:*",
    "@usertour/select": "workspace:*",
    "@usertour/switch": "workspace:*",
    "@usertour/tabs": "workspace:*",
    "@usertour/tailwind": "workspace:*",
    "@usertour/textarea": "workspace:*",
    "@usertour/tooltip": "workspace:*",
    "@usertour/helpers": "workspace:^",
    "class-variance-authority": "^0.4.0",
    "date-fns": "^2.30.0",
