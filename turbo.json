{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["build/**", "dist/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "@usertour/types#build",
        "@usertour/helpers#build",
        "@usertour-packages/constants#build"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
